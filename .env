# The homepage service requires root permissions whereas the rest should run with $USER permissions
HOMEPAGE_PUID=0
HOMEPAGE_PGID=0
PUID=1000
PGID=1000

# Ensure you change this to point to where the Exodus project folder is in your system
PROJECT_FOLDER=/path/to/exodus
# If you have additional storage drive you would like to keep track of, you can edit it here
# Otherwise, comment the volume out on the homepage service
SECONDARY_STORAGE=/path/to/extra/drive

# Edit this variable to change the password for the PiHole web portal
WEBPASSWORD=password